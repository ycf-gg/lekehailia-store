{
    "database": {
        "rules": "firebase-database.rules.json"
    },
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            ".firebaserc",
            ".firebase/**",
            ".git/**",
            ".gitignore",
            "node_modules/**",
            "*.md",
            "package*.json"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "**/*.@(js|css)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=3600"
                    }
                ]
            },
            {
                "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=86400"
                    }
                ]
            }
        ]
    }
}